<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>FREELANCE AMANAH</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    
    body {
      font-family: 'Inter', sans-serif;
      background: linear-gradient(135deg, #0a0a0a 0%, #1a0a2e 50%, #0a0a0a 100%);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #fff;
      overflow-x: hidden;
    }

    /* Animated background */
    body::before {
      content: '';
      position: fixed;
      top: -50%;
      left: -50%;
      width: 200%;
      height: 200%;
      background: radial-gradient(ellipse at center, rgba(138, 43, 226, 0.08) 0%, transparent 70%);
      animation: rotate 30s linear infinite;
      z-index: 0;
    }

    @keyframes rotate {
      from { transform: rotate(0deg); }
      to { transform: rotate(360deg); }
    }

    .container {
      position: relative;
      z-index: 1;
      text-align: center;
      padding: 20px;
      width: 100%;
      max-width: 500px;
    }

    .logo {
      width: 80px;
      height: 80px;
      margin: 0 auto 10px;
      background: linear-gradient(135deg, #7c3aed, #a855f7);
      border-radius: 20px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 36px;
      animation: float 3s ease-in-out infinite;
      box-shadow: 0 0 40px rgba(124, 58, 237, 0.3);
    }

    @keyframes float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-10px); }
    }

    .title {
      font-size: clamp(28px, 6vw, 48px);
      font-weight: 900;
      letter-spacing: 3px;
      margin-bottom: 5px;
      background: linear-gradient(135deg, #7c3aed, #c084fc, #7c3aed);
      background-size: 200% auto;
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      animation: shimmer 3s linear infinite;
    }

    @keyframes shimmer {
      from { background-position: 0% center; }
      to { background-position: 200% center; }
    }

    .subtitle {
      font-size: 14px;
      color: rgba(255, 255, 255, 0.5);
      letter-spacing: 2px;
      margin-bottom: 40px;
      text-transform: uppercase;
    }

    .buttons {
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    .btn {
      padding: 18px 30px;
      border: none;
      border-radius: 16px;
      font-size: 16px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s ease;
      position: relative;
      overflow: hidden;
      letter-spacing: 1px;
      font-family: 'Inter', sans-serif;
    }

    .btn-admin {
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(124, 58, 237, 0.3);
      color: #c084fc;
    }

    .btn-admin:hover {
      background: rgba(124, 58, 237, 0.15);
      border-color: #7c3aed;
      transform: translateY(-2px);
      box-shadow: 0 10px 30px rgba(124, 58, 237, 0.2);
    }

    .btn-member {
      background: linear-gradient(135deg, #7c3aed, #6d28d9);
      color: #fff;
      box-shadow: 0 4px 20px rgba(124, 58, 237, 0.3);
    }

    .btn-member:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 40px rgba(124, 58, 237, 0.5);
    }

    .discord-float {
      position: fixed;
      bottom: 30px;
      right: 30px;
      width: 60px;
      height: 60px;
      background: #5865F2;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      box-shadow: 0 4px 20px rgba(88, 101, 242, 0.4);
      transition: all 0.3s ease;
      z-index: 100;
      text-decoration: none;
    }

    .discord-float:hover {
      transform: scale(1.1);
      box-shadow: 0 8px 30px rgba(88, 101, 242, 0.6);
    }

    .discord-float svg {
      width: 30px;
      height: 30px;
      fill: white;
    }

    .discord-float .tooltip {
      position: absolute;
      right: 70px;
      background: #5865F2;
      color: white;
      padding: 8px 16px;
      border-radius: 8px;
      font-size: 13px;
      font-weight: 500;
      white-space: nowrap;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.3s;
    }

    .discord-float:hover .tooltip {
      opacity: 1;
    }

    /* Modal */
    .modal-overlay {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(0, 0, 0, 0.8);
      z-index: 200;
      align-items: center;
      justify-content: center;
      backdrop-filter: blur(5px);
    }

    .modal-overlay.active {
      display: flex;
    }

    .modal {
      background: linear-gradient(135deg, #1a0a2e, #0f0a1a);
      border: 1px solid rgba(124, 58, 237, 0.3);
      border-radius: 20px;
      padding: 30px;
      width: 90%;
      max-width: 400px;
      text-align: center;
      animation: modalIn 0.3s ease;
    }

    @keyframes modalIn {
      from { transform: scale(0.9); opacity: 0; }
      to { transform: scale(1); opacity: 1; }
    }

    .modal h2 {
      font-size: 20px;
      margin-bottom: 8px;
      color: #c084fc;
    }

    .modal p {
      font-size: 14px;
      color: rgba(255, 255, 255, 0.5);
      margin-bottom: 20px;
    }

    .modal input {
      width: 100%;
      padding: 14px 16px;
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(124, 58, 237, 0.3);
      border-radius: 12px;
      color: #fff;
      font-size: 16px;
      text-align: center;
      letter-spacing: 2px;
      outline: none;
      transition: border-color 0.3s;
    }

    .modal input:focus {
      border-color: #7c3aed;
    }

    .modal .btn-submit {
      width: 100%;
      padding: 14px;
      margin-top: 16px;
      background: linear-gradient(135deg, #7c3aed, #6d28d9);
      border: none;
      border-radius: 12px;
      color: #fff;
      font-size: 16px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s;
    }

    .modal .btn-submit:hover {
      opacity: 0.9;
      transform: translateY(-1px);
    }

    .error-msg {
      color: #ef4444;
      font-size: 13px;
      margin-top: 10px;
      display: none;
    }

    @media (max-width: 480px) {
      .discord-float {
        bottom: 20px;
        right: 20px;
        width: 50px;
        height: 50px;
      }
      
      .discord-float svg {
        width: 25px;
        height: 25px;
      }
      
      .discord-float .tooltip {
        display: none;
      }
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="logo">🛡️</div>
    <h1 class="title">FREELANCE AMANAH</h1>
    <p class="subtitle">Platform Setoran Terpercaya</p>
    
    <div class="buttons">
      <button class="btn btn-admin" onclick="openAdminModal()">🔐 Halaman Admin</button>
      <button class="btn btn-member" onclick="location.href='/member'">👥 Halaman Member</button>
    </div>
  </div>

  <!-- Admin Password Modal -->
  <div class="modal-overlay" id="adminModal">
    <div class="modal">
      <h2>🔐 Akses Admin</h2>
      <p>Masukkan password untuk masuk</p>
      <input type="password" id="adminPass" placeholder="Password" autocomplete="off">
      <p class="error-msg" id="adminError">Password salah!</p>
      <button class="btn-submit" onclick="adminLogin()">Masuk</button>
    </div>
  </div>

  <!-- Discord Float -->
  <a href="https://discord.gg/VhmgYdgxV" target="_blank" class="discord-float">
    <svg viewBox="0 0 24 24">
      <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/>
    </svg>
    <span class="tooltip">Join Discord</span>
  </a>

  <script>
    function openAdminModal() {
      document.getElementById('adminModal').classList.add('active');
      document.getElementById('adminPass').focus();
    }

    document.getElementById('adminModal').addEventListener('click', function(e) {
      if (e.target === this) {
        this.classList.remove('active');
        document.getElementById('adminError').style.display = 'none';
        document.getElementById('adminPass').value = '';
      }
    });

    document.getElementById('adminPass').addEventListener('keypress', function(e) {
      if (e.key === 'Enter') adminLogin();
    });

    async function adminLogin() {
      const password = document.getElementById('adminPass').value;
      const res = await fetch('/admin/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ password })
      });
      const data = await res.json();
      if (data.success) {
        location.href = '/admin/dashboard';
      } else {
        document.getElementById('adminError').style.display = 'block';
        document.getElementById('adminPass').value = '';
      }
    }
  </script>
</body>
</html>
